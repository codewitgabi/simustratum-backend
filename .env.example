PORT=8000

# PostgreSQL connection URL (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/simustratum
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# Google OAuth (optional — leave blank to skip audience validation)
GOOGLE_CLIENT_ID=

# Anthropic (Claude) — used for live panelist question generation
ANTHROPIC_API_KEY=

# Gemini — fallback question generation provider if Anthropic is unavailable
# (rate limited, out of credit, connection error, etc.)
GEMINI_API_KEY=

# Qdrant — vector store for embedded session documents (uploaded papers, etc.)
# Leave QDRANT_API_KEY blank for a local/self-hosted instance.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=session_documents

# Cloudinary — stores the original uploaded document file
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# CORS — comma-separated list of allowed origins (leave blank to allow all)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Swagger docs basic auth (optional)
DOCS_AUTH_USERNAME=
DOCS_AUTH_PASSWORD=

LOG_LEVEL=INFO
